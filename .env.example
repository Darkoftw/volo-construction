# =============================================================================
# VOLO SST — Variables d'environnement Firebase
# =============================================================================
# Copier ce fichier vers .env et remplir les valeurs
#   cp .env.example .env
#
# IMPORTANT : Ne JAMAIS commiter le fichier .env
# =============================================================================

# --- Firebase Project ---
# Trouvable dans : Firebase Console > Project Settings > General
FIREBASE_PROJECT_ID=volo-sst-prod
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=volo-sst-prod.firebaseapp.com
FIREBASE_STORAGE_BUCKET=volo-sst-prod.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abc123def456

# --- Firebase Realtime Database ---
# Utilisé pour le chat temps réel (agenda.html)
FIREBASE_DATABASE_URL=https://volo-sst-prod-default-rtdb.firebaseio.com

# --- Firebase Admin (scripts serveur, seed, Netlify Functions) ---
# Option 1 : Chemin vers le fichier service account JSON
# Téléchargeable dans : Firebase Console > Project Settings > Service Accounts > Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccountKey.json

# Option 2 : Variables individuelles (recommandé pour Netlify)
# Netlify ne supporte pas les fichiers JSON — utiliser les variables
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@volo-sst-prod.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# --- Région Firestore ---
# OBLIGATOIRE : northamerica-northeast1 (Montréal) — conformité Loi 25
FIRESTORE_REGION=northamerica-northeast1

# --- Admin Secret (Netlify Functions) ---
# Protège les endpoints set-custom-claims et create-user
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# À configurer dans : Netlify > Site settings > Environment variables
ADMIN_SECRET=REMPLACER_PAR_UN_SECRET_64_CHARS_HEX

# --- Netlify Functions ---
# Endpoints déployés automatiquement avec le site
# set-custom-claims : POST { uid, role } + header x-admin-secret
# create-user       : POST { email, password, displayName, role, voloId, region, ville } + header x-admin-secret
# Usage :
#   curl -X POST https://your-site.netlify.app/.netlify/functions/set-custom-claims \
#     -H "Content-Type: application/json" \
#     -H "x-admin-secret: $ADMIN_SECRET" \
#     -d '{"uid":"abc123","role":"chef"}'
#
#   curl -X POST https://your-site.netlify.app/.netlify/functions/create-user \
#     -H "Content-Type: application/json" \
#     -H "x-admin-secret: $ADMIN_SECRET" \
#     -d '{"email":"user@volo.com","password":"pass123","displayName":"Jean","role":"sauveteur","voloId":"V0205","region":"ESTRIE"}'

# --- Webhooks Make.com (existant, sera retiré en Phase 4) ---
MAKE_WEBHOOK_PRINCIPAL=https://hook.us2.make.com/wm4fvbqy87nfcuf111azq02l3w2a87sh
MAKE_WEBHOOK_URGENCES=https://hook.us2.make.com/eha54bbek46jrg1yp88939167v7ngveh

# --- Open-Meteo (widget météo) ---
# Pas de clé API requise — API gratuite
# Coordonnées Sherbrooke (par défaut)
WEATHER_LAT=45.40
WEATHER_LON=-71.89

# --- Environnement ---
# development | staging | production
NODE_ENV=development

# --- Debug ---
# Activer les logs détaillés Firebase (true/false)
FIREBASE_DEBUG=false
